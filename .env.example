# ——— Obligatoires ———
# Token du bot (Discord Developer Portal → Bot → Reset Token si compromis)
DISCORD_TOKEN=

# Application ID (Discord Developer Portal → OAuth2 → Application ID)
DISCORD_CLIENT_ID=

# ID du serveur où enregistrer les slash commands (clic droit sur le serveur → Copier l'identifiant)
DISCORD_GUILD_ID=

# ——— Optionnel ———
# ID Discord de l'utilisateur autorisé à gérer la whitelist (/whitelist). Si absent, défaut: 546735493346230272
# WHITELIST_ADMIN_ID=

# URL du webhook pour les notifications tâches (complétion, retard, programme de la semaine). Si absent, valeur par défaut utilisée.
# TASKS_WEBHOOK_URL=

# Debug tâches : logs détaillés en console (import HTML/.gan, responsables, etc.)
# DEBUG_TASKS=1
# ou TASKS_DEBUG=1
# Optionnel : écrire aussi dans data/tasks-debug.log
# TASKS_DEBUG_LOG=1
